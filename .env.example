# =============================================================================
# CLAIMLY - ENVIRONMENT VARIABLES EXAMPLE
# =============================================================================
# Salin file ini ke:
#   - .env.local          → untuk development lokal (npm run dev)
#   - .env.docker         → untuk deployment Docker (npm run build:docker)
#
# PENTING: Jangan commit file .env yang berisi nilai asli ke Git!
# =============================================================================

# === NEXT.JS FRONTEND (PUBLIC) ===
# URL yang dapat diakses oleh browser pengguna
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_CHATBOT_WS_URL=ws://localhost:8000/ws/chat

# Untuk development lokal:
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Untuk deployment Docker (gunakan host.docker.internal agar bisa diakses
# dari dalam container DAN dari browser di mesin host):
NEXT_PUBLIC_KEYCLOAK_URL=http://host.docker.internal:8080
NEXT_PUBLIC_SUPABASE_URL=http://host.docker.internal:54321

# === SUPABASE CREDENTIALS ===
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === KEYCLOAK ===
KEYCLOAK_CLIENT_ID=claimly-supabase
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret

# === RATE LIMITING (UPSTASH REDIS) ===
# Dapatkan dari: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# === REDIS (INTERNAL DOCKER) ===
# Untuk Docker: gunakan nama service container
# Untuk development lokal: gunakan localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# === DATABASE (SUPABASE INTERNAL) ===
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# === URL INTERNAL DOCKER ===
# URL yang digunakan oleh server-side Next.js untuk terhubung ke service lain
# di dalam Docker network (menggunakan nama container, bukan localhost)
SUPABASE_INTERNAL_URL=http://supabase_kong_claimly:8000
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# === SUPABASE INTERNAL SECRETS ===
# Generate dengan: openssl rand -base64 64
SECRET_KEY_BASE=your_secret_key_base_at_least_64_chars
JWT_SECRET=your_jwt_secret_at_least_32_chars
ANON_KEY=your_supabase_anon_key
SERVICE_ROLE_KEY=your_supabase_service_role_key

# === ADDITIONAL CONFIG ===
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
