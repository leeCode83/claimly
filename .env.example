# === NEXT.JS FRONTEND ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_KEYCLOAK_URL=http://keycloak:8080
NEXT_PUBLIC_SUPABASE_URL=http://kong:54321
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# === KEYCLOAK ===
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_ID=claimly-supabase
KEYCLOAK_CLIENT_SECRET=your_client_secret

# === REDIS ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# === DATABASE (SUPABASE) ===
POSTGRES_PASSWORD=postgres
DB_PORT=54322

# === INTERNAL NETWORKING (FOR DOCKER COMPOSE) ===
# This allows the frontend to talk to other containers using service names
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres
